{
  "exchange": {
    "name": "binance",
    "key": "",
    "secret": "",
    "ccxt_config": {
      "enableRateLimit": true,
      "options": {
        "defaultType": "swap"
      },
      "aiohttp_proxy": "http://127.0.0.1:3067",
      "proxies": {
        "http": "socks5://127.0.0.1:3067",
        "https": "socks5h://127.0.0.1:3067"
      }
    },
    "pair_whitelist": [
      "HYPE/USDT:USDT",
      "ZEC/USDT:USDT",
      "BEAT/USDT:USDT",
      "IN/USDT:USDT",
      "GRASS/USDT:USDT",
      "XAU/USDT:USDT",
      "ONDO/USDT:USDT",
      "TAO/USDT:USDT",
      "WLD/USDT:USDT",
      "XAG/USDT:USDT"
    ],
    "pair_blacklist": []
  },
  "trading_mode": "futures",
  "margin_mode": "cross",
  "stake_currency": "USDT",
  "stake_amount": 50,
  "dry_run": true,
  "dry_run_wallet": 1000,
  "max_open_trades": 15,
  "timeframe": "5m",
  "timezone": "Asia/Shanghai",
  "datadir": "user_data",
  "db_url": "sqlite:///tradesv3.dryrun_smallcap_ml_bt.sqlite",
  "bot_name": "SmallCapML-BT",
  "pairlists": [
    {
      "method": "StaticPairList"
    }
  ],
  "entry_pricing": {
    "price_side": "same",
    "use_order_book": true,
    "order_book_top": 1
  },
  "exit_pricing": {
    "price_side": "same",
    "use_order_book": true,
    "order_book_top": 1
  },
  "unfilledtimeout": {
    "entry": 15,
    "exit": 15,
    "exit_timeout_count": 0,
    "unit": "minutes"
  },
  "freqai": {
    "enabled": true,
    "identifier": "smallcap_ml_v1",
    "live_retrain_hours": 0,
    "train_period_days": 30,
    "backtest_period_days": 7,
    "model_save_type": "joblib",
    "fit_live_predictions_candles": 300,
    "purge_old_models": true,
    "save_backtest_models": true,
    "continual_learning": false,
    "write_metrics_to_disk": true,
    "data_kitchen_thread_count": 2,
    "feature_parameters": {
      "include_timeframes": ["15m", "1h"],
      "include_corr_pairlist": ["BTC/USDT:USDT"],
      "label_period_candles": 20,
      "include_shifted_candles": 2,
      "DI_threshold": 0.9,
      "weight_factor": 0.8,
      "principal_component_analysis": false,
      "use_SVM_to_remove_outliers": true,
      "indicator_max_period_candles": 100,
      "indicator_periods_candles": [10, 20, 50]
    },
    "data_split_parameters": {
      "test_size": 0.15,
      "random_state": 42,
      "shuffle": false
    },
    "model_training_parameters": {
      "n_estimators": 500,
      "learning_rate": 0.02,
      "max_depth": 6,
      "num_leaves": 63,
      "min_child_samples": 50,
      "subsample": 0.8,
      "colsample_bytree": 0.8,
      "reg_alpha": 0.1,
      "reg_lambda": 0.1,
      "verbosity": -1,
      "random_state": 42
    }
  },
  "freqaimodel": "LightGBMRegressor"
}
